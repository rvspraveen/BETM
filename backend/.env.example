
# ──────────────────────────────────────────────────────────────────────────────
# ERCOT Copilot — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
APP_VERSION=1.0.0

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Default: openai (GPT-4o)
# Switch to anthropic to use Claude 3.5 Sonnet
LLM_PROVIDER=openai

# OpenAI (required)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4o

# Anthropic (optional — only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Embeddings always use OpenAI
EMBEDDING_MODEL=text-embedding-3-small

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot_secret
POSTGRES_HOST=localhost        # Use 'db' inside Docker
POSTGRES_PORT=5432
POSTGRES_DB=ercot_copilot

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0   # Use redis://redis:6379/0 inside Docker

# ── RAG Settings ──────────────────────────────────────────────────────────────
MAX_RETRIEVAL_CHUNKS=8
CONFIDENCE_THRESHOLD=0.72
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
